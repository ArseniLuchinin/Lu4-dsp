{
    "conveyors": [
        {
            "modules": [
                {
                    "name": "RRCCompute",
                    "params": {
                        "normalize gain": true,
                        "rolloff": 0.35,
                        "sample rate": "$SAMPLE_RATE",
                        "samples per symbol": "$QPSK_SPS",
                        "span symbols": 8,
                        "symbol rate": "$QPSK_SYMBOL_RATE"
                    }
                },
                {
                    "name": "VirtualTX",
                    "params": {
                        "tag": "fir_rrc_coeff"
                    }
                }
            ],
            "name": "FIR coefficients conveyor"
        },
        {
            "modules": [
                {
                    "name": "FileSrc",
                    "params": {
                        "data type": "complex",
                        "file name": "$QPSK_FILE",
                        "max size": "$MAX_SIZE"
                    }
                },
                {
                    "name": "FIR-filter",
                    "params": {
                        "coefficients type": "real",
                        "filter order": 1025,
                        "log energy": false,
                        "taps": "@fir_rrc_coeff"
                    }
                },
                {
                    "name": "Decimator",
                    "params": {
                        "offset": 0,
                        "samples per symbol": "$QPSK_SPS"
                    }
                },
                {
                    "name": "CarrierRecovery",
                    "params": {
                        "order": 4
                    }
                },
                {
                    "name": "QPSKDecision"
                },
                {
                    "name": "BitPacker",
                    "params": {
                        "bit order": "msb-first",
                        "discard leading bits": 16,
                        "flush tail": false
                    }
                },
                {
                    "name": "TextFileWriter",
                    "params": {
                        "file name": "results/qpsk_decoded.txt"
                    }
                }
            ],
            "name": "Main conveyor"
        }
    ],
    "variables": "/home/luchinin/my_source/Course_poject/Server/variables.toml"
}
