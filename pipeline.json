{
  "variables": "/home/luchinin/my_source/Course_poject/Server/variables.toml",
  "conveyors": [
    {
      "name": "FIR coefficients conveyor",
      "modules": [
        {
          "name": "RRCCompute",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "symbol rate": "$QPSK_SYMBOL_RATE",
            "rolloff": 0.35,
            "span symbols": 8,
            "samples per symbol": "$QPSK_SPS",
            "normalize gain": true
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fir_rrc_coeff"
          }
        }
      ]
    },
    {
      "name": "Main conveyor",
      "modules": [
        {
          "name": "FileSrc",
          "params": {
            "file name": "/home/luchinin/my_source/Course_poject/Server/signal_examples/qpsk_signal.bin",
            "data type": "complex",
            "max size": "$MAX_SIZE"
          }
        },
        {
          "name": "FIR-filter",
          "params": {
            "filter order": 1025,
            "coefficients type": "real",
            "log energy": false,
            "taps": "@fir_rrc_coeff"
          }
        },
        {
          "name": "Decimator",
          "params": {
            "samples per symbol": "$QPSK_SPS",
            "offset": 0
          }
        },
        {
          "name": "CarrierRecovery",
          "params": {
            "order": 4
          }
        },
        {
          "name": "QPSKDecision"
        },
        {
          "name": "BitPacker",
          "params": {
            "bit order": "msb-first",
            "flush tail": false,
            "discard leading bits": 16
          }
        },
        {
          "name": "TextFileWriter",
          "params": {
            "file name": "/home/luchinin/my_source/Course_poject/Server/signal_examples/qpsk_decoded.txt"
          }
        }
      ]
    }
  ]
}
