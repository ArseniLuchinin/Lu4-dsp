{
  "variables": "/home/luchinin/my_source/Course_poject/Server/variables.toml",
  "conveyors": [
    {
      "name": "FIR coefficients conveyor",
      "modules": [
        {
          "name": "BandPassCompute",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "filter order": 129,
            "block size": "$MAX_SIZE",
            "low cutoff": -140000.0,
            "high cutoff": -150000.0
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fir_bandpass_coeff"
          }
        }
      ]
    },
    {
      "name": "RX conveyor",
      "modules": [
        {
          "name": "VirtualRX",
          "params": {
            "tag": "fft_out"
          }
        },
        {
          "name": "CS2AS"
        },
        {
          "name": "FFT_Shift",
          "params": {
            "fft size": "$FFT_SIZE",
            "window size": "$FFT_WINDOW"
          }
        },
        {
          "name": "SpectrogramPlot",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "fft size": "$FFT_SIZE",
            "hop size": "$FFT_HOP_SIZE",
            "window size": "$FFT_WINDOW",
            "centered spectrum": true,
            "freq min": -1048576.0,
            "freq max": 1048576.0,
            "save path": "/home/luchinin/my_source/Course_poject/Server/signal_examples/spectrogramm"
          }
        }
      ]
    },
    {
      "name": "Main conveyor",
      "modules": [
        {
          "name": "FileSrc",
          "params": {
            "file name": "/home/luchinin/my_source/Course_poject/Server/signal_examples/amc_signal.bin",
            "data type": "complex",
            "max size": "$MAX_SIZE"
          }
        },
        {
          "name": "FIR-filter",
          "params": {
            "coefficients data tag": "fir_bandpass_coeff",
            "filter order": 129
          }
        },
        {
          "name": "FFT",
          "params": {
            "fft size": "$FFT_SIZE",
            "hop size": "$FFT_HOP_SIZE"
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fft_out"
          }
        }
      ]
    }
  ]
}
