{
  "variables": "/home/luchinin/my_source/Course_poject/Server/variables.toml",
  "conveyors": [
    {
      "name": "FIR coefficients conveyor",
      "modules": [
        {
          "name": "BandPassComputeComplex",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "filter order": 8191,
            "low cutoff":  -120000.0,
            "high cutoff":  250000.0
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fir_bandpass_coeff"
          }
        }
      ]
    },
    {
      "name": "RX conveyor",
      "modules": [
        {
          "name": "VirtualRX",
          "params": {
            "tag": "fft_out"
          }
        },
        {
          "name": "CS2AS",
          "params": {
            "fft size": "$FFT_SIZE",
            "normalize by fft size": true
          }
        },
        {
          "name": "FFT_Shift",
          "params": {
            "fft size": "$FFT_SIZE",
            "window size": "$FFT_WINDOW"
          }
        },
        {
          "name": "SpectrogramPlot",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "fft size": "$FFT_SIZE",
            "hop size": "$FFT_HOP_SIZE",
            "window size": "$FFT_WINDOW",
            "centered spectrum": true,
            "freq min": -1048576.0,
            "freq max": 1048576.0,
            "db min": -120.0,
            "db max": -10.0,
            "mask below db" : -10.0,
            "save path": "/home/luchinin/my_source/Course_poject/Server/signal_examples/spectrogramm_filtered_"
          }
        }
      ]
    },
    {
      "name": "Main conveyor",
      "modules": [
        {
          "name": "FileSrc",
          "params": {
            "file name": "/home/luchinin/my_source/Course_poject/Server/signal_examples/amc_signal.bin",
            "data type": "complex",
            "max size": "$MAX_SIZE"
          }
        },
        {
          "name": "FIR-filter",
          "params": {
            "coefficients data tag": "fir_bandpass_coeff",
            "filter order": 8191,
            "coefficients type": "auto",
            "log energy": false 
          }
        },
        {
          "name": "FFT",
          "params": {
            "fft size": "$FFT_SIZE",
            "hop size": "$FFT_HOP_SIZE"
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fft_out"
          }
        }
      ]
    }
  ]
}
