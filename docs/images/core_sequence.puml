@startuml
skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2

title Core — последовательность запуска конвейера

actor "main()" as Main
participant "ConveyorOrchestrator" as CO
participant "ConveyorFactory" as CF
participant "ModuleFactory" as MF
participant "Conveyor" as CV
participant "IModule" as MOD
participant "Variables" as VAR
participant "VirtualTransmitter" as VT

group Инициализация системы
    activate Main
    Main -> CO ++ : ConveyorOrchestrator(configPath)
    CO -> CO : читает pipeline.json
    Main -> CO : load()
    deactivate CO
end

group Запуск конвейеров
    Main -> CO ++ : run()
    CO -> VAR ++ : load("variables.toml")
    return
    CO -> CO : buildConveyors()

    loop Для каждого конфига
        CO -> CO : создаёт std::thread

        CO -> CF ++ : createFromJsonObject(config)
        CF -> CV ++ : make_shared<Conveyor>(name)

        loop Для каждого модуля в JSON
            CF -> MF ++ : createModule(name)
            MF -> MF : findModule(name) → Redis
            MF -> MF : dlopen(path)
            MF -> MF : dlsym("createModule")
            MF -> MOD ++ : createModule() → IModule*
            return module
            deactivate MF

            alt параметр содержит $VAR
                CF -> MOD ++ : fetchParam(name, value)
                MOD -> VAR ++ : get(varName)
                return varValue
                MOD -> MOD : setParam(name, varValue)
            else параметр содержит @tag
                CF -> MOD ++ : fetchParam(name, value)
                MOD -> VT ++ : registerRx(tag)
                return
                MOD -> VT ++ : waitRxData(tag)
                return shared_ptr<IData>
                MOD -> MOD : setParam(name, rxData)
            else прямое значение
                CF -> MOD ++ : fetchParam(name, value)
                MOD -> MOD : setParam(name, value)
            end
            deactivate MOD

            CF -> CV : addModule(module)
        end

        return conveyor
        deactivate CF

        CO -> CV : init()
        loop Для каждого модуля
            CV -> MOD ++ : init()
            return
        end

        loop while(conveyor->run())
            CV -> MOD ++ : run()
            return
            CV -> MOD ++ : getData()
            return shared_ptr<IData>

            alt data->size() == 0
                CV --> CV : finished
            else данные есть
                loop Для каждого следующего модуля
                    CV -> MOD ++ : setData(data)
                    return
                    CV -> MOD ++ : run()
                    return
                    CV -> MOD ++ : getData()
                    return shared_ptr<IData>
                end
            end
        end

        deactivate CV
    end

    CO -> CO : join() всех потоков
    deactivate CO
end

deactivate Main
@enduml
