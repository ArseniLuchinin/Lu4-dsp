{
  "variables": "tests/TestData/variables/qpsk_variables.toml",
  "conveyors": [
    {
      "name": "FIR coefficients conveyor",
      "modules": [
        {
          "name": "RRCCompute",
          "params": {
            "sample rate": "$SAMPLE_RATE",
            "symbol rate": "$QPSK_SYMBOL_RATE",
            "rolloff": 0.35,
            "span symbols": 8,
            "samples per symbol": "$QPSK_SPS",
            "normalize gain": true
          }
        },
        {
          "name": "VirtualTX",
          "params": {
            "tag": "fir_rrc_coeff"
          }
        }
      ]
    },
    {
      "name": "QPSK RRC pipeline",
      "modules": [
        {
          "name": "FileSrc",
          "params": {
            "file name": "tests/TestData/signals/qpsk_rrc_signal.bin",
            "data type": "complex",
            "max size": "$MAX_SIZE"
          }
        },
        {
          "name": "FIR-filter",
          "params": {
            "taps": "@fir_rrc_coeff",
            "filter order": 1025,
            "coefficients type": "real",
            "log energy": false
          }
        },
        {
          "name": "Decimator",
          "params": {
            "samples per symbol": "$QPSK_SPS",
            "offset": 0
          }
        },
        {
          "name": "CarrierPhaseEstimator",
          "params": {
            "phase tag": "qpsk_phase"
          }
        },
        {
          "name": "PhaseRotator",
          "params": {
            "phase tag": "qpsk_phase"
          }
        },
        {
          "name": "QPSKDecision"
        },
        {
          "name": "BitPacker",
          "params": {
            "bit order": "msb-first",
            "flush tail": false,
            "discard leading bits": 8
          }
        },
        {
          "name": "TextFileWriter",
          "params": {
            "file name": "tests/TestData/signals/qpsk_rrc_decoded.txt"
          }
        }
      ]
    }
  ]
}
